# Server-only base URL of the Spring Boot backend (origin, no trailing slash).
# The REST prefix /api is added by the fetch wrapper.
# NOTE: intentionally NOT prefixed with NEXT_PUBLIC_ — it must never reach the browser.
API_BASE_URL=http://localhost:8080

# Public canonical origin of THIS site (no trailing slash). Used for SEO:
# metadataBase, canonical URLs, Open Graph, sitemap and robots. Set this to the
# real production domain (e.g. https://churchhub.vn) before deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
